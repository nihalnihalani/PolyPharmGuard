{
  "name": "polypharmguard",
  "version": "1.0.0",
  "description": "Clinical polypharmacy reasoning engine",
  "type": "module",
  "main": "dist/mcp-server/index.js",
  "scripts": {
    "dev": "tsx src/mcp-server/index.ts",
    "build": "tsc",
    "start": "node dist/mcp-server/index.js",
    "agent:dev": "tsx src/a2a-agent/index.ts",
    "agent:start": "node dist/a2a-agent/index.js",
    "validate:kb": "tsx scripts/validate-kb.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/tools tests/knowledge-base",
    "test:e2e": "vitest run tests/e2e",
    "lint": "eslint src/",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@google/genai": "^1.0.0",
    "zod": "^3.25.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0"
  }
}
