# --- Gemini (Clinical Reasoning LLM) ---
GEMINI_API_KEY=

# --- FHIR Server ---
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4
FHIR_ACCESS_TOKEN=
PATIENT_ID=mrs-johnson-001

# --- MCP Server ---
# stdio (default, for Claude Desktop / local dev) or http (for marketplace deploy)
MCP_TRANSPORT=stdio
MCP_PORT=3000

# --- A2A Agent ---
A2A_AGENT_PORT=8000

# --- Prompt Opinion Marketplace ---
# API key issued by https://app.promptopinion.ai when registering an entry.
# Required to run `npm run publish:po`.
PROMPT_OPINION_API_KEY=

# --- openFDA (optional, raises rate limits) ---
OPENFDA_API_KEY=

# --- Guardrails (optional) ---
NEMO_GUARDRAILS_CONFIG=
